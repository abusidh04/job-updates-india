rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // JOBS COLLECTION
    // Public can read all jobs (needed for homepage, job listing, etc.)
    // Only authenticated admin can create, update, delete jobs
    // ---------------------------------------------------------------
    match /jobs/{jobId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // ---------------------------------------------------------------
    // Block all other collections by default
    // ---------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}